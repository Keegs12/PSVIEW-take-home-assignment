# Copy to .env.local and fill in. NEVER commit .env.local.
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (sensible defaults — override if you like).
# Reasoning/classification step (the "intelligence"): use the strongest model.
PSVIEW_REASONING_MODEL=claude-opus-4-8
# High-volume generation loop (messages): fast + capable.
PSVIEW_WRITER_MODEL=claude-sonnet-4-6
# URL research → form auto-fill. Defaults to the writer model if unset (keeps research cheap).
PSVIEW_RESEARCH_MODEL=claude-sonnet-4-6

# Reply-message self-verification depth (grounding + persona audit):
#   judge     = full LLM audit + one auto-revision on failure (default)
#   heuristic = code-only persona checks, no extra model call (cheapest)
#   off       = skip verification entirely
PSVIEW_VERIFY_MODE=judge
